<Page
    x:Class="UnderRun.Views.UnderRunPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:controls="using:CommunityToolkit.WinUI.Controls"
    xmlns:cvt="using:UnderRun.Converters"
    mc:Ignorable="d">

    <Page.Resources>
        <cvt:BoolToColorConverter x:Key="BoolToColorConverter" />
    </Page.Resources>

    <ScrollViewer>
        <StackPanel Spacing="10" Padding="20">

            <controls:SettingsCard Header="UnderRun Notification Sound" Description="Toggle UnderRun notification sound on or off">
                <ToggleSwitch IsOn="{Binding IsSoundEnabled, Mode=TwoWay}" />
            </controls:SettingsCard>

            <controls:SettingsCard Header="Always On Top" Description="Always keep window on top">
                <ToggleSwitch IsOn="{Binding IsAlwaysOnTop, Mode=TwoWay}" />
            </controls:SettingsCard>

            <controls:SettingsCard Header="Run on Startup" Description="Launch app on Windows startup">
                <ToggleSwitch IsOn="{Binding IsRunOnStartup, Mode=TwoWay}" />
            </controls:SettingsCard>

            <TextBlock Text="Underrun Status" FontSize="20" FontWeight="Bold" Margin="0,20,0,0"/>
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="8" Padding="16">
                <StackPanel>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="150"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="Pipe A :" Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" FontSize="18"/>
                        <TextBlock Text="{Binding PipeA}" Foreground="{Binding IsPipeAError, Converter={StaticResource BoolToColorConverter}}" Grid.Row="0" Grid.Column="1" FontSize="18"/>

                        <TextBlock Text="Pipe B :" Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" FontSize="18"/>
                        <TextBlock Text="{Binding PipeB}" Foreground="{Binding IsPipeBError, Converter={StaticResource BoolToColorConverter}}" Grid.Row="1" Grid.Column="1" FontSize="18"/>

                        <TextBlock Text="Pipe C :" Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" FontSize="18"/>
                        <TextBlock Text="{Binding PipeC}" Foreground="{Binding IsPipeCError, Converter={StaticResource BoolToColorConverter}}" Grid.Row="2" Grid.Column="1" FontSize="18"/>

                        <TextBlock Text="Pipe D :" Grid.Row="3" Grid.Column="0" VerticalAlignment="Center" FontSize="18"/>
                        <TextBlock Text="{Binding PipeD}" Foreground="{Binding IsPipeDError, Converter={StaticResource BoolToColorConverter}}" Grid.Row="3" Grid.Column="1" FontSize="18"/>
                    </Grid>
                </StackPanel>
            </Border>

            <TextBlock Text="TDR Status" FontSize="20" FontWeight="Bold" Margin="0,20,0,0"/>
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="8" Padding="16">
                <StackPanel>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="150"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="Driver Version:" VerticalAlignment="Center" FontSize="18"/>
                        <TextBlock Text="{Binding DriverVersion}" Grid.Column="1" VerticalAlignment="Center" FontSize="18"/>
                    </Grid>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</Page>
